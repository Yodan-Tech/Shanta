{
  "buildCommand": "pnpm db:deploy && pnpm build",
  "crons": [
    {
      "path": "/api/v1/cron/drain-notifications",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/v1/cron/check-stuck-shipments",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/v1/cron/escrow-timeout",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/v1/cron/frequency-report",
      "schedule": "0 9 * * 0"
    }
  ]
}
